[gd_resource type="Resource" script_class="AntRule" load_steps=4 format=3]

[ext_resource type="Script" path="res://logic/behavior/ant_rule.gd" id="1_rule"]
[ext_resource type="Resource" path="res://resources/expressions/conditions/should_rest_at_colony.tres" id="2_cond"]
[ext_resource type="Resource" path="res://resources/behavior/actions/action_rest.tres" id="3_act"]

[resource]
script = ExtResource("1_rule")
name = "rest rule"
condition = ExtResource("2_cond")
action = ExtResource("3_act")
priority = 10
enabled = true
description = "Rest when at colony with health or energy below 90%"
