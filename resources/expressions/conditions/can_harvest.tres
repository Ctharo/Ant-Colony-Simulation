[gd_resource type="Resource" script_class="Logic" load_steps=3 format=3]

[ext_resource type="Script" path="res://logic/logic.gd" id="1_logic"]
[ext_resource type="Resource" path="res://resources/expressions/sense/reach/food_in_reach_count.tres" id="2_reach"]

[resource]
script = ExtResource("1_logic")
name = "can harvest"
expression_string = "food_in_reach_count > 0 and not is_carrying_food"
nested_expressions = Array[ExtResource("1_logic")]([ExtResource("2_reach")])
description = "Food is within reach and the ant has free mandibles"
type = 1
